---
import '../../styles/global.css';
import neighborhoods from '../../cities.json';

export function getStaticPaths() {
  return neighborhoods.map(c => ({
    params: { city: c.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') },
    props: { cityName: c }
  }));
}

const { city } = Astro.params;
const { cityName } = Astro.props;
